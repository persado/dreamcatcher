{
  "name": "dreamcatcher",
  "description": "Dreamcatcher - Image/PDF exporter using Puppeteer",
  "version": "2.4.0",
  "private": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node start.js",
    "debug": "node --nolazy start.js",
    "inspect": "node --nolazy --inspect start.js",
    "test": "PUPPETEER_ARGS=--no-sandbox,--disable-setuid-sandbox,--disable-dev-shm-usage,--disable-web-security ./node_modules/.bin/mocha test",
    "test-with-coverage": "./node_modules/.bin/nyc --reporter=text --reporter=html mocha"
  },
  "dependencies": {
    "@sentry/node": "^7.52.1",
    "@sentry/tracing": "^7.52.1",
    "async": "^3.2.4",
    "async-retry": "^1.3.3",
    "body-parser": "^1.19.0",
    "cookie-parser": "~1.4.3",
    "debug": "^4.2.0",
    "express": "^4.18.1",
    "lodash": "^4.17.21",
    "morgan": "^1.10.0",
    "on-finished": "^2.3.0",
    "puppeteer": "^24.0.0",
    "puppeteer-cluster": "^0.24.0",
    "url": "^0.11.0"
  },
  "devDependencies": {
    "autocannon": "^8.0.0",
    "chai": "^4.3.4",
    "chai-http": "^4.3.0",
    "mocha": "^11.7.6",
    "nyc": "^18.0.0"
  }
}
